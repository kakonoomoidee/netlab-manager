{
  "name": "managable-server",
  "version": "1.2.0",
  "codename": "Phoenix",
  "description": "Backend server for provisioning and managing isolated SSH/dev instances with real-time WebSocket monitoring.",
  "main": "src/app.js",
  "type": "commonjs",
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "scripts": {
    "start": "node src/app.js",
    "dev": "nodemon src/app.js",
    "test": "echo \"Error: no test specified\" && exit 1",
    "lint": "eslint . --ext .js",
    "lint:fix": "eslint . --ext .js --fix",
    "format": "prettier --write \"src/**/*.js\""
  },
  "keywords": [
    "ssh",
    "provisioning",
    "docker",
    "websocket",
    "express",
    "server-manager"
  ],
  "author": {
    "name": "Rizki Ramadan",
    "url": "https://github.com/kakonoomoide"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kakonoomoide/managable-server.git"
  },
  "bugs": {
    "url": "https://github.com/kakonoomoide/managable-server/issues"
  },
  "homepage": "https://github.com/kakonoomoide/managable-server#readme",
  "private": true,
  "dependencies": {
    "bcrypt": "^6.0.0",
    "date-fns": "^4.4.0",
    "dotenv": "^17.4.2",
    "ejs": "^6.0.1",
    "express": "^5.2.1",
    "express-ejs-layouts": "^2.5.1",
    "express-session": "^1.19.0",
    "helmet": "^8.3.0",
    "ms": "^2.1.3",
    "multer": "^2.2.0",
    "socket.io": "^4.8.3",
    "sqlite3": "^6.0.1",
    "ssh2": "^1.17.0",
    "ssh2-sftp-client": "^12.1.1",
    "ws": "^8.21.1"
  },
  "devDependencies": {
    "eslint": "^9.15.0",
    "nodemon": "^3.1.14",
    "prettier": "^3.3.3"
  }
}
