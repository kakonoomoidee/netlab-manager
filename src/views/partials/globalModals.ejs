<!-- Global Edit Modal -->
<div id="globalEditModal" class="hidden fixed inset-0 bg-gray-600 bg-opacity-50 overflow-y-auto h-full w-full z-50 flex items-center justify-center">
    <div class="relative bg-white rounded-lg shadow-xl w-full max-w-md p-6">
        <div class="flex justify-between items-center mb-5">
            <h3 class="text-lg font-bold text-gray-900" id="globalEditTitle">Edit Item</h3>
            <button id="globalEditCancelTopBtn" type="button" class="text-gray-400 hover:text-gray-500">
                <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" /></svg>
            </button>
        </div>
        <div id="globalEditErrorContainer" class="hidden bg-red-50 border-l-4 border-red-500 text-red-700 p-4 rounded shadow-sm mb-4"></div>
        <form id="globalEditForm" class="space-y-4">
            <input type="hidden" id="global_edit_id" name="id">
            
            <!-- Dynamic Form Fields will be inserted here by JS if needed, but for now we reuse the server structure -->
            <div id="globalEditFormFields">
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Hostname</label>
                    <input type="text" id="global_edit_hostname" name="hostname" required class="w-full border-gray-300 rounded-md shadow-sm focus:ring-primary focus:border-primary p-2 border">
                </div>
                <div class="mt-4">
                    <label class="block text-sm font-medium text-gray-700 mb-1">IP Address</label>
                    <input type="text" id="global_edit_ip" name="ip" required pattern="^(?:(?:25[0-5]|2[0-4][0-9]|[01]?[0-9][0-9]?)\.){3}(?:25[0-5]|2[0-4][0-9]|[01]?[0-9][0-9]?)$" class="w-full border-gray-300 rounded-md shadow-sm focus:ring-primary focus:border-primary p-2 border">
                </div>
                <div class="grid grid-cols-2 gap-4 mt-4">
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">SSH Port</label>
                        <input type="number" id="global_edit_ssh_port" name="ssh_port" required class="w-full border-gray-300 rounded-md shadow-sm focus:ring-primary focus:border-primary p-2 border">
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Username</label>
                        <input type="text" id="global_edit_username" name="username" required class="w-full border-gray-300 rounded-md shadow-sm focus:ring-primary focus:border-primary p-2 border">
                    </div>
                </div>
                <div class="mt-4">
                    <label class="block text-sm font-medium text-gray-700 mb-1">Role</label>
                    <select id="global_edit_role" name="role" class="w-full border-gray-300 rounded-md shadow-sm focus:ring-primary focus:border-primary p-2 border">
                        <option value="node">Worker Node</option>
                        <option value="master">Master Node</option>
                        <option value="database">Database</option>
                    </select>
                </div>
            </div>

            <div class="mt-6 flex justify-end space-x-3">
                <button type="button" id="globalEditCancelBtn" class="bg-white py-2 px-4 border border-gray-300 rounded-md shadow-sm text-sm font-medium text-gray-700 hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-primary">Cancel</button>
                <button type="submit" id="globalEditSubmitBtn" class="bg-primary py-2 px-4 border border-transparent rounded-md shadow-sm text-sm font-medium text-white hover:bg-secondary focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-primary">Save Changes</button>
            </div>
        </form>
    </div>
</div>

<!-- Global Confirm Modal -->
<div id="globalConfirmModal" class="hidden fixed inset-0 bg-gray-600 bg-opacity-50 overflow-y-auto h-full w-full z-50 flex items-center justify-center">
    <div class="relative bg-white rounded-lg shadow-xl w-full max-w-sm p-6 text-center">
        <div class="mx-auto flex items-center justify-center h-12 w-12 rounded-full bg-red-100 mb-4">
            <svg class="h-6 w-6 text-red-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
            </svg>
        </div>
        <h3 class="text-lg font-bold text-gray-900 mb-2" id="globalConfirmTitle">Confirm Action</h3>
        <p class="text-sm text-gray-500 mb-6" id="globalConfirmMessage">Are you sure you want to proceed?</p>
        
        <div class="flex justify-center space-x-3">
            <button type="button" id="globalConfirmCancelBtn" class="bg-white py-2 px-4 border border-gray-300 rounded-md shadow-sm text-sm font-medium text-gray-700 hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-primary w-full">Cancel</button>
            <button type="button" id="globalConfirmSubmitBtn" class="bg-red-600 py-2 px-4 border border-transparent rounded-md shadow-sm text-sm font-medium text-white hover:bg-red-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-red-500 w-full">Confirm</button>
        </div>
    </div>
</div>

<!-- Global Stats Modal -->
<div id="globalStatsModal" class="hidden fixed inset-0 bg-gray-600 bg-opacity-50 overflow-y-auto h-full w-full z-50 flex items-center justify-center">
    <div class="relative bg-white rounded-lg shadow-xl w-full max-w-lg p-6">
        <div class="flex justify-between items-center mb-5">
            <h3 class="text-lg font-bold text-gray-900">Server Statistics: <span id="globalStatsHostname" class="text-primary"></span></h3>
            <button id="globalStatsCancelTopBtn" type="button" class="text-gray-400 hover:text-gray-500">
                <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" /></svg>
            </button>
        </div>
        
        <div class="space-y-6">
            <!-- CPU -->
            <div>
                <div class="flex justify-between items-center mb-1">
                    <span class="text-sm font-medium text-gray-700">CPU Usage</span>
                    <span id="globalStatsCpuVal" class="text-sm font-medium text-gray-700">-</span>
                </div>
                <div class="w-full bg-gray-100 rounded-full h-2.5 overflow-hidden">
                    <div id="globalStatsCpuBar" class="bg-blue-500 h-2.5 rounded-full transition-all duration-300" style="width: 0%"></div>
                </div>
            </div>
            
            <!-- RAM -->
            <div>
                <div class="flex justify-between items-center mb-1">
                    <span class="text-sm font-medium text-gray-700">RAM Usage</span>
                    <span id="globalStatsRamVal" class="text-sm font-medium text-gray-700">-</span>
                </div>
                <div class="w-full bg-gray-100 rounded-full h-2.5 overflow-hidden">
                    <div id="globalStatsRamBar" class="bg-emerald-500 h-2.5 rounded-full transition-all duration-300" style="width: 0%"></div>
                </div>
            </div>
            
            <!-- Disk -->
            <div>
                <div class="flex justify-between items-center mb-1">
                    <span class="text-sm font-medium text-gray-700">Disk Usage</span>
                    <span id="globalStatsDiskVal" class="text-sm font-medium text-gray-700">-</span>
                </div>
                <div class="w-full bg-gray-100 rounded-full h-2.5 overflow-hidden">
                    <div id="globalStatsDiskBar" class="bg-amber-500 h-2.5 rounded-full transition-all duration-300" style="width: 0%"></div>
                </div>
            </div>
            
            <!-- Temp -->
            <div class="flex items-center justify-between pt-2 border-t border-gray-100">
                <span class="text-sm font-medium text-gray-700">Temperature</span>
                <div class="flex items-center">
                    <svg class="w-5 h-5 mr-1 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 18.657A8 8 0 016.343 7.343S7 9 9 10c0-2 .5-5 2.986-7C14 5 16.09 5.777 17.656 7.343A7.975 7.975 0 0120 13a7.975 7.975 0 01-2.343 5.657z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.879 16.121A3 3 0 1012.015 11L11 14H9c0 .768.293 1.536.879 2.121z"></path></svg>
                    <span id="globalStatsTempVal" class="text-lg font-bold text-gray-700">-</span>
                </div>
            </div>
        </div>

        <div class="mt-8 flex justify-end">
            <button type="button" id="globalStatsCloseBtn" class="bg-white py-2 px-4 border border-gray-300 rounded-md shadow-sm text-sm font-medium text-gray-700 hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-primary">Close</button>
        </div>
    </div>
</div>

<!-- Global Terminal Modal -->
<div id="globalTerminalModal" class="hidden fixed inset-0 bg-gray-900 bg-opacity-90 overflow-hidden h-full w-full z-50 flex flex-col p-4 sm:p-8">
    <div class="bg-gray-900 rounded-xl shadow-2xl border border-gray-700 flex-1 flex flex-col overflow-hidden max-w-6xl w-full mx-auto">
        <!-- Terminal Header -->
        <div class="flex items-center justify-between px-4 py-3 bg-gray-800 border-b border-gray-700">
            <div class="flex items-center">
                <div class="w-3 h-3 rounded-full bg-red-500 mr-2 cursor-pointer hover:bg-red-400 transition-colors" id="globalTerminalCloseDotBtn" title="Close Terminal"></div>
                <div class="w-3 h-3 rounded-full bg-yellow-500 mr-2"></div>
                <div class="w-3 h-3 rounded-full bg-green-500 mr-2"></div>
                <span class="ml-2 text-sm text-gray-300 font-mono font-medium" id="globalTerminalHostname">Loading...</span>
            </div>
            <div id="globalTerminalConnectionStatus" class="text-xs font-mono text-yellow-400 flex items-center">
                <span class="w-2 h-2 rounded-full bg-yellow-400 mr-2 animate-pulse"></span> Connecting...
            </div>
        </div>
        <!-- Terminal Body -->
        <div class="flex-1 p-2 bg-[#111827]">
            <div id="globalTerminalContainer" class="w-full h-full"></div>
        </div>
    </div>
</div>

<!-- xterm.js dependencies -->
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/xterm@5.3.0/css/xterm.css" />
<script src="https://cdn.jsdelivr.net/npm/xterm@5.3.0/lib/xterm.js"></script>
<script src="https://cdn.jsdelivr.net/npm/xterm-addon-fit@0.8.0/lib/xterm-addon-fit.js"></script>
<script src="https://cdn.jsdelivr.net/npm/xterm-addon-webLinks@0.9.0/lib/xterm-addon-webLinks.js"></script>
