<div class="px-8 py-6 max-w-7xl mx-auto">
    <div class="mb-8">
        <h1 class="text-2xl font-bold text-gray-900">Git Deployments</h1>
        <p class="text-gray-500 mt-1">Deploy code directly to remote servers via Git clone and pull operations.</p>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
        <!-- Configuration Panel -->
        <div class="lg:col-span-1 space-y-6">
            <div class="bg-white shadow overflow-hidden sm:rounded-lg border border-gray-200">
                <div class="px-4 py-5 sm:px-6 bg-gray-50 border-b border-gray-200">
                    <h3 class="text-lg leading-6 font-medium text-gray-900">Deployment Config</h3>
                    <p class="mt-1 max-w-2xl text-sm text-gray-500">Specify repository details to deploy.</p>
                </div>
                <div class="px-4 py-5 sm:p-6 space-y-4">
                    <% if (userRole === 'admin') { %>
                        <div>
                            <label for="serverSelect" class="block text-sm font-medium text-gray-700 mb-1">Target Server</label>
                            <select id="serverSelect" class="block w-full pl-3 pr-10 py-2 text-base border-gray-300 focus:outline-none focus:ring-primary focus:border-primary sm:text-sm rounded-md border shadow-sm">
                                <option value="">Loading servers...</option>
                            </select>
                        </div>
                        
                        <div>
                            <label for="repoUrl" class="block text-sm font-medium text-gray-700 mb-1">Repository URL</label>
                            <input type="text" id="repoUrl" class="block w-full border-gray-300 rounded-md shadow-sm focus:ring-primary focus:border-primary sm:text-sm border px-3 py-2" placeholder="https://github.com/username/repo.git">
                        </div>

                        <div>
                            <label for="targetDir" class="block text-sm font-medium text-gray-700 mb-1">Target Directory (Absolute)</label>
                            <input type="text" id="targetDir" class="block w-full border-gray-300 rounded-md shadow-sm focus:ring-primary focus:border-primary sm:text-sm border px-3 py-2" placeholder="/var/www/my-app">
                        </div>

                        <div>
                            <label for="branch" class="block text-sm font-medium text-gray-700 mb-1">Branch</label>
                            <input type="text" id="branch" value="main" class="block w-full border-gray-300 rounded-md shadow-sm focus:ring-primary focus:border-primary sm:text-sm border px-3 py-2" placeholder="main">
                        </div>
                    <% } else { %>
                        <div class="text-center py-6">
                            <svg class="mx-auto h-12 w-12 text-gray-400 mb-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" /></svg>
                            <h3 class="text-lg font-medium text-gray-900">Access Denied</h3>
                            <p class="mt-2 text-sm text-gray-500">Deployments require administrator privileges.</p>
                        </div>
                    <% } %>
                </div>
            </div>
            
            <% if (userRole === 'admin') { %>
            <button id="deployBtn" class="w-full flex justify-center py-2.5 px-4 border border-transparent rounded-md shadow-sm text-sm font-medium text-white bg-primary hover:bg-secondary focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-primary disabled:opacity-50 disabled:cursor-not-allowed transition-colors" disabled>
                Deploy Repository
            </button>
            <% } %>

            <div id="errorBanner" class="hidden rounded-md bg-red-50 p-4 border border-red-200">
                <div class="flex">
                    <div class="ml-3">
                        <h3 class="text-sm font-medium text-red-800" id="errorText"></h3>
                    </div>
                </div>
            </div>
        </div>

        <!-- Terminal Output Panel -->
        <div class="lg:col-span-2">
            <div class="bg-white shadow overflow-hidden sm:rounded-lg border border-gray-200 h-full flex flex-col" style="min-height: 400px;">
                <div class="px-4 py-5 sm:px-6 bg-gray-50 border-b border-gray-200 flex justify-between items-center">
                    <div>
                        <h3 class="text-lg leading-6 font-medium text-gray-900">Execution Logs</h3>
                        <p class="mt-1 max-w-2xl text-sm text-gray-500">Live output from the deployment script.</p>
                    </div>
                </div>
                <div class="flex-1 p-0 relative h-full w-full bg-[#1e1e1e]">
                    <div id="logOutput" class="absolute inset-0 w-full h-full p-4 font-mono text-sm text-gray-300 overflow-y-auto whitespace-pre-wrap">Waiting for deployment execution...</div>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    document.addEventListener('DOMContentLoaded', () => {
        const USER_ROLE = '<%- userRole %>';
        const serverSelect = document.getElementById('serverSelect');
        const repoUrl = document.getElementById('repoUrl');
        const targetDir = document.getElementById('targetDir');
        const branch = document.getElementById('branch');
        const deployBtn = document.getElementById('deployBtn');
        const errorBanner = document.getElementById('errorBanner');
        const errorText = document.getElementById('errorText');
        const logOutput = document.getElementById('logOutput');

        function populateServerSelect() {
            if (!serverSelect) return;
            if (!window.NetLabStore || !window.NetLabStore.servers) return;
            
            const currentVal = serverSelect.value;
            serverSelect.innerHTML = '<option value="">Select a server...</option>';
            
            const onlineServers = window.NetLabStore.servers.filter(s => s.status === 'online');
            
            onlineServers.forEach(server => {
                const opt = document.createElement('option');
                opt.value = server.id;
                opt.textContent = `${server.hostname} (${server.ip})`;
                if (server.id.toString() === currentVal) opt.selected = true;
                serverSelect.appendChild(opt);
            });

            validateForm();
        }

        function validateForm() {
            if (!deployBtn) return;
            if (serverSelect.value && repoUrl.value.trim() && targetDir.value.trim()) {
                deployBtn.disabled = false;
            } else {
                deployBtn.disabled = true;
            }
        }

        window.addEventListener('netlab-state-updated', populateServerSelect);
        if (window.NetLabStore && window.NetLabStore.servers) populateServerSelect();

        if (serverSelect) serverSelect.addEventListener('change', validateForm);
        if (repoUrl) repoUrl.addEventListener('input', validateForm);
        if (targetDir) targetDir.addEventListener('input', validateForm);

        if (deployBtn) {
            deployBtn.addEventListener('click', async () => {
                errorBanner.classList.add('hidden');
                
                const payload = {
                    serverId: serverSelect.value,
                    repoUrl: repoUrl.value.trim(),
                    targetDirectory: targetDir.value.trim(),
                    branch: branch.value.trim() || 'main'
                };

                deployBtn.disabled = true;
                deployBtn.innerHTML = '<svg class="animate-spin -ml-1 mr-2 h-4 w-4 text-white inline-block" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg> Deploying...';
                
                logOutput.innerHTML = `<span class="text-yellow-400">Initiating deployment to ${targetDir.value}...</span>\n`;

                try {
                    const res = await fetch('/deploy/api/deploy/git', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify(payload)
                    });

                    const data = await res.json();
                    
                    if (!res.ok) {
                        throw new Error(data.error || 'Deployment failed');
                    }

                    if (data.result) {
                        if (data.result.stdout) {
                            logOutput.innerHTML += escapeHtml(data.result.stdout);
                        }
                        if (data.result.stderr) {
                            logOutput.innerHTML += `<span class="text-red-400">${escapeHtml(data.result.stderr)}</span>`;
                        }
                        logOutput.innerHTML += `\n<span class="text-green-400">Deployment process finished.</span>`;
                    }
                    
                } catch (err) {
                    errorText.textContent = err.message;
                    errorBanner.classList.remove('hidden');
                    logOutput.innerHTML += `\n<span class="text-red-500">Error: ${escapeHtml(err.message)}</span>`;
                } finally {
                    deployBtn.disabled = false;
                    deployBtn.textContent = 'Deploy Repository';
                    logOutput.scrollTop = logOutput.scrollHeight;
                }
            });
        }

        function escapeHtml(unsafe) {
            if (!unsafe) return '';
            return unsafe
                 .replace(/&/g, "&amp;")
                 .replace(/</g, "&lt;")
                 .replace(/>/g, "&gt;")
                 .replace(/"/g, "&quot;")
                 .replace(/'/g, "&#039;");
        }
    });
</script>
