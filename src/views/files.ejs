<div class="px-8 py-6 max-w-7xl mx-auto">
    <div class="flex justify-between items-center mb-6">
        <div>
            <h1 class="text-2xl font-bold text-gray-900">File Manager</h1>
            <p class="text-gray-500 mt-1">Navigate, upload, and download files remotely via SFTP.</p>
        </div>
        <div class="flex space-x-4">
            <select id="serverSelect" class="block w-64 pl-3 pr-10 py-2 text-base border-gray-300 focus:outline-none focus:ring-primary focus:border-primary sm:text-sm rounded-md shadow-sm border">
                <option value="">Select a server...</option>
            </select>
            <button id="refreshBtn" class="bg-white p-2 border border-gray-300 rounded-md shadow-sm text-gray-700 hover:bg-gray-50 focus:outline-none transition-colors" title="Refresh">
                <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" /></svg>
            </button>
            <% if (userRole === 'admin') { %>
            <button id="uploadBtn" class="bg-primary hover:bg-secondary text-white font-bold py-2 px-4 rounded-lg flex items-center transition-colors shadow-sm disabled:opacity-50 disabled:cursor-not-allowed" disabled>
                <svg class="w-5 h-5 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-8l-4-4m0 0L8 8m4-4v12" /></svg>
                Upload File
            </button>
            <input type="file" id="fileInput" class="hidden">
            <% } %>
        </div>
    </div>

    <!-- Breadcrumbs -->
    <nav class="flex mb-4" aria-label="Breadcrumb">
        <ol id="breadcrumbList" class="flex items-center space-x-2 text-sm text-gray-500 font-mono bg-white px-4 py-3 rounded-lg shadow-sm border border-gray-200 w-full overflow-x-auto">
            <li><span>/</span></li>
        </ol>
    </nav>

    <!-- File Explorer -->
    <div class="bg-white shadow overflow-hidden sm:rounded-lg border border-gray-200">
        <div class="overflow-x-auto">
            <table class="min-w-full divide-y divide-gray-200">
                <thead class="bg-gray-50">
                    <tr>
                        <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider w-1/2">Name</th>
                        <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Size</th>
                        <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Modified</th>
                        <th scope="col" class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">Actions</th>
                    </tr>
                </thead>
                <tbody id="fileTableBody" class="bg-white divide-y divide-gray-200">
                    <tr>
                        <td colspan="4" class="px-6 py-12 text-center text-gray-500">
                            <svg class="mx-auto h-12 w-12 text-gray-400 mb-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 12h14M5 12a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v4a2 2 0 01-2 2M5 12a2 2 0 00-2 2v4a2 2 0 002 2h14a2 2 0 002-2v-4a2 2 0 00-2-2m-2-4h.01M17 16h.01" /></svg>
                            <p class="text-lg font-medium">Please select a server</p>
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>
</div>

<script>
    document.addEventListener('DOMContentLoaded', () => {
        const USER_ROLE = '<%- userRole %>';
        const serverSelect = document.getElementById('serverSelect');
        const refreshBtn = document.getElementById('refreshBtn');
        const fileTableBody = document.getElementById('fileTableBody');
        const breadcrumbList = document.getElementById('breadcrumbList');
        const uploadBtn = document.getElementById('uploadBtn');
        const fileInput = document.getElementById('fileInput');

        let currentPath = '/';

        /**
         * Populates the server select dropdown.
         */
        function populateServerSelect() {
            if (!window.NetLabStore || !window.NetLabStore.servers) return;
            
            const currentVal = serverSelect.value;
            serverSelect.innerHTML = '<option value="">Select a server...</option>';
            
            const onlineServers = window.NetLabStore.servers.filter(s => s.status === 'online');
            
            onlineServers.forEach(server => {
                const opt = document.createElement('option');
                opt.value = server.id;
                opt.textContent = `${server.hostname} (${server.ip})`;
                if (server.id.toString() === currentVal) opt.selected = true;
                serverSelect.appendChild(opt);
            });

            if (uploadBtn) uploadBtn.disabled = !serverSelect.value;
        }

        window.addEventListener('netlab-state-updated', populateServerSelect);
        if (window.NetLabStore && window.NetLabStore.servers) populateServerSelect();

        serverSelect.addEventListener('change', () => {
            currentPath = '/';
            if (uploadBtn) uploadBtn.disabled = !serverSelect.value;
            if (serverSelect.value) {
                fetchFiles();
            } else {
                fileTableBody.innerHTML = '<tr><td colspan="4" class="px-6 py-12 text-center text-gray-500">Please select a server</td></tr>';
                breadcrumbList.innerHTML = '<li><span>/</span></li>';
            }
        });

        refreshBtn.addEventListener('click', () => {
            if (serverSelect.value) fetchFiles();
        });

        /**
         * Fetches and renders files for the current path.
         */
        async function fetchFiles() {
            const serverId = serverSelect.value;
            if (!serverId) return;

            fileTableBody.innerHTML = '<tr><td colspan="4" class="px-6 py-12 text-center text-gray-500"><svg class="animate-spin mx-auto h-8 w-8 text-primary" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg></td></tr>';
            renderBreadcrumbs();

            try {
                const res = await fetch(`/files/api/${serverId}/files?path=${encodeURIComponent(currentPath)}`);
                const data = await res.json();
                
                if (!res.ok) throw new Error(data.error || 'Failed to list directory');

                currentPath = data.path; // update to actual absolute path if '.' was used
                renderBreadcrumbs();
                renderFiles(data.files);
            } catch (err) {
                fileTableBody.innerHTML = `<tr><td colspan="4" class="px-6 py-6 text-center text-red-500">Error: ${escapeHtml(err.message)}</td></tr>`;
            }
        }

        /**
         * Renders the breadcrumb navigation.
         */
        function renderBreadcrumbs() {
            breadcrumbList.innerHTML = '';
            
            const rootLi = document.createElement('li');
            rootLi.className = 'cursor-pointer text-blue-600 hover:text-blue-800 transition-colors font-bold';
            rootLi.textContent = 'root';
            rootLi.onclick = () => { currentPath = '/'; fetchFiles(); };
            breadcrumbList.appendChild(rootLi);

            if (currentPath === '/') return;

            const parts = currentPath.split('/').filter(p => p);
            let builtPath = '';

            parts.forEach((part, index) => {
                builtPath += '/' + part;
                const pathCopy = builtPath; // Capture for closure
                
                const separator = document.createElement('li');
                separator.innerHTML = '<svg class="w-4 h-4 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>';
                breadcrumbList.appendChild(separator);

                const partLi = document.createElement('li');
                partLi.className = 'cursor-pointer transition-colors';
                if (index === parts.length - 1) {
                    partLi.classList.add('font-bold', 'text-gray-900', 'cursor-default');
                } else {
                    partLi.classList.add('text-blue-600', 'hover:text-blue-800');
                    partLi.onclick = () => { currentPath = pathCopy; fetchFiles(); };
                }
                partLi.textContent = part;
                breadcrumbList.appendChild(partLi);
            });
        }

        /**
         * Renders the file list table.
         * @param {Array} files
         */
        function renderFiles(files) {
            fileTableBody.innerHTML = '';
            
            if (currentPath !== '/') {
                const tr = document.createElement('tr');
                tr.className = 'hover:bg-gray-50 cursor-pointer group transition-colors';
                tr.onclick = () => {
                    const parts = currentPath.split('/').filter(p => p);
                    parts.pop();
                    currentPath = '/' + parts.join('/');
                    if (currentPath === '') currentPath = '/';
                    fetchFiles();
                };
                tr.innerHTML = `
                    <td colspan="4" class="px-6 py-4 whitespace-nowrap text-sm font-medium text-gray-900 flex items-center">
                        <svg class="w-5 h-5 text-gray-400 mr-3" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 7v10a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-6l-2-2H5a2 2 0 00-2 2z" /></svg>
                        ..
                    </td>
                `;
                fileTableBody.appendChild(tr);
            }

            if (!files || files.length === 0) {
                const tr = document.createElement('tr');
                tr.innerHTML = '<td colspan="4" class="px-6 py-8 text-center text-gray-500 text-sm">Directory is empty</td>';
                fileTableBody.appendChild(tr);
                return;
            }

            files.forEach(f => {
                const isDir = f.type === 'd';
                const icon = isDir 
                    ? '<svg class="w-5 h-5 text-blue-400 mr-3" fill="currentColor" viewBox="0 0 20 20"><path d="M2 6a2 2 0 012-2h5l2 2h5a2 2 0 012 2v6a2 2 0 01-2 2H4a2 2 0 01-2-2V6z" /></svg>'
                    : '<svg class="w-5 h-5 text-gray-400 mr-3" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 21h10a2 2 0 002-2V9.414a1 1 0 00-.293-.707l-5.414-5.414A1 1 0 0012.586 3H7a2 2 0 00-2 2v14a2 2 0 002 2z" /></svg>';
                
                let sizeStr = '-';
                if (!isDir && f.size !== undefined) {
                    const kb = f.size / 1024;
                    sizeStr = kb > 1024 ? (kb / 1024).toFixed(2) + ' MB' : kb.toFixed(2) + ' KB';
                }

                const dateStr = f.modifyTime ? new Date(f.modifyTime).toLocaleString() : '-';
                
                const tr = document.createElement('tr');
                tr.className = 'hover:bg-gray-50 transition-colors';
                
                const nameCell = `<td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-gray-900 flex items-center ${isDir ? 'cursor-pointer hover:text-primary' : ''}" ${isDir ? `onclick="window.navigateDir('${escapeHtml(f.name)}' )"` : ''}>${icon} ${escapeHtml(f.name)}</td>`;
                const sizeCell = `<td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">${sizeStr}</td>`;
                const dateCell = `<td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">${dateStr}</td>`;
                
                const fullPath = currentPath === '/' ? `/${f.name}` : `${currentPath}/${f.name}`;
                
                let actionHtml = '';
                if (!isDir) {
                    actionHtml += `<a href="/files/api/${serverSelect.value}/files/download?path=${encodeURIComponent(fullPath)}" class="text-blue-600 hover:text-blue-900 mr-4 font-semibold" title="Download" download>Download</a>`;
                }
                
                if (USER_ROLE === 'admin') {
                    actionHtml += `<button onclick="deleteFile('${escapeHtml(f.name)}', '${f.type}')" class="text-red-600 hover:text-red-900 font-semibold" title="Delete">Delete</button>`;
                }

                const actionCell = `<td class="px-6 py-4 whitespace-nowrap text-right text-sm">${actionHtml}</td>`;
                
                tr.innerHTML = nameCell + sizeCell + dateCell + actionCell;
                fileTableBody.appendChild(tr);
            });
        }

        window.navigateDir = function(dirName) {
            currentPath = currentPath === '/' ? `/${dirName}` : `${currentPath}/${dirName}`;
            fetchFiles();
        };

        window.deleteFile = async function(itemName, type) {
            if (!confirm(`Are you sure you want to permanently delete ${itemName}?`)) return;
            
            const serverId = serverSelect.value;
            const fullPath = currentPath === '/' ? `/${itemName}` : `${currentPath}/${itemName}`;

            try {
                const res = await fetch(`/files/api/${serverId}/files?path=${encodeURIComponent(fullPath)}&type=${type}`, {
                    method: 'DELETE'
                });
                const data = await res.json();
                if (!res.ok) throw new Error(data.error || 'Failed to delete');
                fetchFiles();
            } catch (err) {
                alert('Error: ' + err.message);
            }
        };

        if (uploadBtn && fileInput) {
            uploadBtn.addEventListener('click', () => {
                if (serverSelect.value) fileInput.click();
            });

            fileInput.addEventListener('change', async (e) => {
                if (!e.target.files.length) return;
                
                const file = e.target.files[0];
                const serverId = serverSelect.value;
                const formData = new FormData();
                formData.append('file', file);
                
                uploadBtn.disabled = true;
                const originalContent = uploadBtn.innerHTML;
                uploadBtn.innerHTML = '<svg class="animate-spin h-5 w-5 mr-2 text-white" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg> Uploading...';

                try {
                    const res = await fetch(`/files/api/${serverId}/files/upload?path=${encodeURIComponent(currentPath)}`, {
                        method: 'POST',
                        body: formData
                    });
                    const data = await res.json();
                    if (!res.ok) throw new Error(data.error || 'Failed to upload');
                    fetchFiles();
                } catch (err) {
                    alert('Upload Error: ' + err.message);
                } finally {
                    uploadBtn.disabled = false;
                    uploadBtn.innerHTML = originalContent;
                    fileInput.value = '';
                }
            });
        }

        /**
         * Escapes HTML to prevent XSS.
         * @param {string} unsafe
         * @returns {string}
         */
        function escapeHtml(unsafe) {
            if (!unsafe) return '';
            return unsafe
                 .replace(/&/g, "&amp;")
                 .replace(/</g, "&lt;")
                 .replace(/>/g, "&gt;")
                 .replace(/"/g, "&quot;")
                 .replace(/'/g, "&#039;");
        }
    });
</script>
